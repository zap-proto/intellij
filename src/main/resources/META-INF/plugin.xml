<idea-plugin>
    <id>org.zapproto.intellij</id>
    <name>ZAP</name>
    <version>2.0</version>
    <vendor url="https://github.com/zap-proto/intellij">zap-proto</vendor>

    <description><![CDATA[
ZAP schema language support for IntelliJ-based IDEs: syntax highlighting, file type and ID generation.
ZAP is a fork of <a href="https://capnproto.org">Cap'n Proto</a> and stays wire- and library-compatible with it; the <code>.zap</code> and <code>.capnp</code> schema extensions are both supported.
]]></description>


    <change-notes><![CDATA[
    <ul>
      <li>Updated for IntelliJ Platform 2025.1</li>
      <li>Support for all JetBrains IDEs</li>
      <li>Bug fixes and compatibility improvements</li>
    </ul>
    ]]></change-notes>

    <idea-version since-build="221" until-build="251.*"/>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Zap file"
                  implementationClass="com.sercapnp.lang.CapnpFileType"
                  fieldName="INSTANCE"
                  language="Zap"
                  extensions="zap;capnp"/>
        <lang.parserDefinition
                language="Zap"
                implementationClass="com.sercapnp.lang.CapnpParserDefinition"/>
        <lang.syntaxHighlighterFactory
                language="Zap"
                implementationClass="com.sercapnp.lang.CapnpSyntaxHighlighterFactory"/>
        <colorSettingsPage implementation="com.sercapnp.lang.CapnpColorSettingsPage"/>
    </extensions>




    <actions>
        <action id="GenerateCapnpID" class="com.sercapnp.actions.GenerateCapnpID" text="Generate ZAP ID"
                description="Generate ZAP id">
            <keyboard-shortcut first-keystroke="control alt A" second-keystroke="G" keymap="$default"/>
            <add-to-group group-id="ToolsMenu" anchor="first" />
        </action>
        <action id="Capnp.New" class="com.sercapnp.actions.NewFileAction" text="ZAP File" description="Create new ZAP file">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFromTemplate"/>
        </action>
    </actions>

</idea-plugin>
